<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Circular Arena - Interactive Art</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            margin: 0;
            overflow: hidden;
            background-color: #050505;
            color: white;
            font-family: 'Pretendard', sans-serif;
        }
        canvas {
            display: block;
            touch-action: none;
        }
        #ui-overlay {
            position: absolute;
            top: 20px;
            left: 20px;
            pointer-events: none;
            opacity: 0.6;
            transition: opacity 0.3s;
        }
        #ui-overlay:hover { opacity: 1; }
        .instructions {
            font-size: 0.8rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }
    </style>
</head>
<body>

    <div id="ui-overlay">
        <h1 class="text-2xl font-bold mb-1">CIRCULAR ARENA</h1>
        <p class="instructions">Move to swirl • Click to burst</p>
    </div>

    <canvas id="artCanvas"></canvas>

    <script>
        /**
         * Circular Arena - Interactive Art
         * 원본 이미지의 색상과 형태를 기반으로 한 입자 시뮬레이션
         */

        const canvas = document.getElementById('artCanvas');
        const ctx = canvas.getContext('2d');

        let width, height;
        let particles = [];
        let ripples = [];
        let mouse = { x: -1000, y: -1000, active: false };
        
        // 원본 이미지에서 추출한 핵심 팔레트
        const palette = [
            '#4CAF50', // Vibrant Green
            '#E91E63', // Pink
            '#FFC107', // Gold/Yellow
            '#03A9F4', // Sky Blue
            '#FF5722', // Orange/Red
            '#F8BBD0', // Soft Pink
            '#C8E6C9'  // Soft Green
        ];

        // 이미지 객체 생성 (사용자가 업로드한 이미지를 활용하기 위한 구조)
        const mainImage = new Image();
        // 실제 환경에서는 업로드된 이미지 경로를 넣습니다. 
        // 여기서는 시각적 보존을 위해 캔버스로 원형 아트의 느낌을 구현합니다.
        mainImage.src = 'image_f5fb34.jpg'; 

        function init() {
            resize();
            createParticles();
            animate();
        }

        function resize() {
            width = window.innerWidth;
            height = window.innerHeight;
            canvas.width = width;
            canvas.height = height;
        }

        window.addEventListener('resize', resize);

        class Particle {
            constructor() {
                this.reset();
            }

            reset() {
                this.x = Math.random() * width;
                this.y = Math.random() * height;
                this.baseX = this.x;
                this.baseY = this.y;
                this.size = Math.random() * 3 + 1;
                this.color = palette[Math.floor(Math.random() * palette.length)];
                this.vx = (Math.random() - 0.5) * 1.5;
                this.vy = (Math.random() - 0.5) * 1.5;
                this.life = Math.random();
                this.angle = Math.random() * Math.PI * 2;
                this.distanceFromCenter = Math.sqrt(Math.pow(this.x - width/2, 2) + Math.pow(this.y - height/2, 2));
            }

            update() {
                // 중앙 원형 아레나 영향 (중력/회전)
                const dx = width / 2 - this.x;
                const dy = height / 2 - this.y;
                const dist = Math.sqrt(dx * dx + dy * dy);
                const force = (Math.min(width, height) * 0.4 - dist) / 1000;

                // 마우스 상호작용
                const mdx = mouse.x - this.x;
                const mdy = mouse.y - this.y;
                const mdist = Math.sqrt(mdx * mdx + mdy * mdy);
                
                if (mdist < 150) {
                    const angle = Math.atan2(mdy, mdx);
                    this.vx -= Math.cos(angle) * 0.2;
                    this.vy -= Math.sin(angle) * 0.2;
                }

                // 회전 운동 유도
                const rotateAngle = Math.atan2(dy, dx) + 0.01;
                const targetX = width / 2 + Math.cos(rotateAngle) * dist;
                const targetY = height / 2 + Math.sin(rotateAngle) * dist;

                this.vx += (targetX - this.x) * 0.001;
                this.vy += (targetY - this.y) * 0.001;

                this.x += this.vx;
                this.y += this.vy;
                this.vx *= 0.98;
                this.vy *= 0.98;

                // 리플 영향
                ripples.forEach(r => {
                    const rdx = r.x - this.x;
                    const rdy = r.y - this.y;
                    const rdist = Math.sqrt(rdx * rdx + rdy * rdy);
                    if (Math.abs(rdist - r.radius) < 10) {
                        const angle = Math.atan2(rdy, rdx);
                        this.vx -= Math.cos(angle) * r.power;
                        this.vy -= Math.sin(angle) * r.power;
                    }
                });
            }

            draw() {
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                ctx.fillStyle = this.color;
                ctx.fill();
            }
        }

        function createParticles() {
            particles = [];
            const count = (width * height) / 2000;
            for (let i = 0; i < count; i++) {
                particles.push(new Particle());
            }
        }

        function drawMainCircle() {
            const centerX = width / 2;
            const centerY = height / 2;
            const radius = Math.min(width, height) * 0.35;

            // 배경 글로우
            const grad = ctx.createRadialGradient(centerX, centerY, 0, centerX, centerY, radius * 1.5);
            grad.addColorStop(0, 'rgba(233, 30, 99, 0.1)');
            grad.addColorStop(1, 'transparent');
            ctx.fillStyle = grad;
            ctx.fillRect(0, 0, width, height);

            // 원본 이미지의 원형 형태를 보존하는 가이드 (이미지가 로드되면 이미지 그림)
            ctx.save();
            ctx.beginPath();
            ctx.arc(centerX, centerY, radius, 0, Math.PI * 2);
            ctx.clip();
            
            try {
                if (mainImage.complete && mainImage.naturalHeight !== 0) {
                    ctx.drawImage(mainImage, centerX - radius, centerY - radius, radius * 2, radius * 2);
                } else {
                    // 이미지 로드 전까지는 추상적인 원형 표현
                    ctx.strokeStyle = 'rgba(255,255,255,0.2)';
                    ctx.lineWidth = 2;
                    ctx.stroke();
                }
            } catch(e) {}
            
            ctx.restore();
            
            // 테두리 효과
            ctx.beginPath();
            ctx.arc(centerX, centerY, radius + 2, 0, Math.PI * 2);
            ctx.strokeStyle = 'rgba(255,255,255,0.1)';
            ctx.stroke();
        }

        function animate() {
            ctx.fillStyle = 'rgba(5, 5, 5, 0.15)';
            ctx.fillRect(0, 0, width, height);

            drawMainCircle();

            particles.forEach(p => {
                p.update();
                p.draw();
            });

            // 리플 업데이트
            for (let i = ripples.length - 1; i >= 0; i--) {
                ripples[i].radius += 10;
                ripples[i].life -= 0.02;
                if (ripples[i].life <= 0) ripples.splice(i, 1);
                else {
                    ctx.beginPath();
                    ctx.arc(ripples[i].x, ripples[i].y, ripples[i].radius, 0, Math.PI * 2);
                    ctx.strokeStyle = `rgba(255, 255, 255, ${ripples[i].life * 0.3})`;
                    ctx.stroke();
                }
            }

            requestAnimationFrame(animate);
        }

        // 사운드 시스템 (Web Audio API)
        const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        function playNote(freq, type = 'sine', decay = 1) {
            const osc = audioCtx.createOscillator();
            const gain = audioCtx.createGain();
            osc.type = type;
            osc.frequency.setValueAtTime(freq, audioCtx.currentTime);
            gain.gain.setValueAtTime(0.1, audioCtx.currentTime);
            gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + decay);
            osc.connect(gain);
            gain.connect(audioCtx.destination);
            osc.start();
            osc.stop(audioCtx.currentTime + decay);
        }

        // 마우스 및 터치 이벤트
        function handleInteraction(e) {
            const x = e.clientX || (e.touches && e.touches[0].clientX);
            const y = e.clientY || (e.touches && e.touches[0].clientY);
            mouse.x = x;
            mouse.y = y;
        }

        window.addEventListener('mousemove', handleInteraction);
        window.addEventListener('touchstart', (e) => {
            if (audioCtx.state === 'suspended') audioCtx.resume();
            handleInteraction(e);
            triggerRipple(mouse.x, mouse.y);
        });

        window.addEventListener('mousedown', () => {
            if (audioCtx.state === 'suspended') audioCtx.resume();
            triggerRipple(mouse.x, mouse.y);
        });

        function triggerRipple(x, y) {
            ripples.push({ x, y, radius: 0, life: 1, power: 5 });
            // 사운드 트리거 (메이저 펜타토닉 스케일 기반 임의 음계)
            const notes = [261.63, 293.66, 329.63, 392.00, 440.00];
            playNote(notes[Math.floor(Math.random() * notes.length)], 'sine', 2);
            
            // 추가 파티클 생성
            for(let i=0; i<10; i++) {
                const p = new Particle();
                p.x = x; p.y = y;
                p.vx = (Math.random()-0.5) * 10;
                p.vy = (Math.random()-0.5) * 10;
                particles.push(p);
                if (particles.length > 1000) particles.shift();
            }
        }

        init();
    </script>
</body>
</html>
