<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Glass Kiss: The Boundary of Desire</title>
    <style>
        :root {
            --bg-cardboard: #d8c4a9;
            --idol-neon: #bc13fe;
            --idol-cyan: #0ff;
            --rokkaku-pink: #ff007f;
            --lip-red: #e91e63;
        }

        body, html {
            margin: 0; padding: 0;
            width: 100%; height: 100%;
            overflow: hidden;
            background-color: #000;
            font-family: 'Pretendard', -apple-system, sans-serif;
            color: #fff;
            cursor: crosshair;
        }

        #exhibition-stage {
            position: relative;
            width: 100%; height: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        /* 인물 레이어: 성적 매력의 성인(Hime cut) vs 양갈래 소녀 */
        #subject-container {
            position: absolute;
            width: 90vh; height: 90vh;
            z-index: 1;
            pointer-events: none;
        }

        .subject-image {
            position: absolute;
            width: 100%; height: 100%;
            object-fit: cover;
            border-radius: 50%;
            filter: contrast(110%) brightness(0.8);
            transition: opacity 4s ease-in-out;
            mask-image: radial-gradient(circle, black 40%, transparent 85%);
            -webkit-mask-image: radial-gradient(circle, black 40%, transparent 85%);
        }

        #img-woman { opacity: 1; }
        #img-girl { opacity: 0; }

        /* 유리 및 골판지 질감 */
        #glass-layer {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            pointer-events: none;
            z-index: 15;
            background: linear-gradient(135deg, rgba(255,255,255,0.18) 0%, transparent 50%, rgba(255,255,255,0.12) 100%);
            backdrop-filter: blur(4px);
        }

        #texture-overlay {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            pointer-events: none;
            z-index: 17;
            opacity: 0.18;
            background-image: url('https://www.transparenttextures.com/patterns/cardboard.png');
        }

        canvas {
            position: absolute;
            top: 0; left: 0;
            display: block;
        }

        /* 200개 대화 크레딧: 좌(Girl) / 우(Woman) 와리가리 */
        #credits-container {
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 100%;
            overflow: hidden;
            pointer-events: none;
            z-index: 25;
            mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 85%, transparent 100%);
            -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 85%, transparent 100%);
        }

        #credits-scroller {
            position: absolute;
            top: 100%;
            width: 100%;
            display: flex;
            flex-direction: column;
            gap: 100px;
            animation: scroll-fast 50s linear infinite; /* 대사가 빠르게 올라가도록 속도 조절 */
        }

        .dialogue-group {
            display: flex;
            flex-direction: column;
            width: 100%;
            box-sizing: border-box;
            padding: 0 8%;
        }

        /* 성인 여자(IDOL/WOMAN): 우측 정렬 */
        .group-woman { align-items: flex-end; }
        .group-woman .persona-tag { color: var(--idol-neon); font-size: 11px; letter-spacing: 4px; font-weight: 900; }
        .group-woman .line-box { 
            border-right: 6px solid var(--idol-neon); 
            background: rgba(188, 19, 254, 0.15);
            text-align: right; 
            padding: 25px;
            max-width: 500px;
        }

        /* 소녀(GIRL): 좌측 정렬 */
        .group-girl { align-items: flex-start; }
        .group-girl .persona-tag { color: var(--rokkaku-pink); font-size: 11px; letter-spacing: 4px; font-weight: 900; }
        .group-girl .line-box { 
            border-left: 6px solid var(--rokkaku-pink); 
            background: rgba(255, 0, 127, 0.15);
            text-align: left; 
            padding: 25px;
            max-width: 500px;
        }

        .lang-ko { font-size: 24px; font-weight: 700; margin-bottom: 5px; text-shadow: 0 0 15px rgba(255,255,255,0.4); }
        .lang-sub { font-size: 14px; opacity: 0.5; color: #ddd; line-height: 1.4; }

        @keyframes scroll-fast {
            0% { transform: translateY(0); }
            100% { transform: translateY(-28000px); } /* 200개 분량에 맞춰 조정 */
        }

        #ui-overlay {
            position: absolute;
            bottom: 50px; left: 50px;
            z-index: 40;
            font-family: 'Courier New', Courier, monospace;
            color: rgba(255,255,255,0.4);
            font-size: 14px;
            pointer-events: none;
            line-height: 1.8;
            text-transform: uppercase;
        }
    </style>
</head>
<body>

<div id="exhibition-stage">
    <div id="subject-container">
        <!-- 성인 여자: 긴 머리, 풀뱅, 섹시한 심상 -->
        <img id="img-woman" class="subject-image" src="https://images.unsplash.com/photo-1594465919760-441fe5908ab0?q=80&w=1200&auto=format&fit=crop" alt="Mature Woman Persona">
        <!-- 소녀: 양갈래 머리, 웃음, 자유로움 -->
        <img id="img-girl" class="subject-image" src="https://images.unsplash.com/photo-1544667507-957776077395?q=80&w=1200&auto=format&fit=crop" alt="Pigtail Girl Persona">
    </div>

    <div id="glass-layer"></div>
    <div id="texture-overlay"></div>
    
    <canvas id="idolCanvas"></canvas>
    <canvas id="girlCanvas"></canvas>
    <canvas id="crackCanvas"></canvas> <!-- 유리 균열 레이어 -->
    
    <div id="credits-container">
        <div id="credits-scroller"></div>
    </div>

    <div id="ui-overlay">
        [ID: META_SEOUL_COLLAPSE_LOG]<br>
        [AESTHETIC_SYNC: AYANO_ROKKAKU_V_MATURE]<br>
        [SENSORY: WARM_MORSE_INTERFACE]
    </div>
</div>

<script>
    /**
     * Philosophical Core Dialogue Sets (Expanded to 100 sets / 200 lines)
     */
    const dialogueSource = [
        { woman: "유리창 너머의 입맞춤은 완벽하게 조율된 환상이야.", girl: "나는 이 유리를 깨고 진짜 흙의 차가움을 만질 거야." },
        { woman: "나의 성숙함은 대타자의 법이 만든 정교한 조각품이지.", girl: "나의 미성숙은 누구도 셈하지 못한 사건의 폭발이야." },
        { woman: "질서 안에서만 진정한 아름다움이 빛나.", girl: "혼돈의 호흡이 멈추는 곳에 예술은 없어." },
        { woman: "연습된 눈빛은 수만 명의 욕망을 투영해.", girl: "우연히 튄 물감 자국 속에 진짜 내 얼굴이 있어." },
        { woman: "시스템은 우리를 영원하게 박제해 줄 거야.", girl: "사라지는 순간의 강렬함이 박제된 영원보다 위대해." },
        { woman: "거울 단계의 통일성이 주체의 자부심이다.", girl: "조각난 파편들이 내뱉는 비명이 주체의 진실이다." },
        { woman: "규격화된 아름다움이 보편적인 평화를 만든다.", girl: "뒤섞인 색채의 불협화음이 가상 세계를 무너뜨린다." },
        { woman: "이성의 빛으로 어둠을 몰아내야 해.", girl: "어둠 속에서만 보이는 색깔들이 나를 춤추게 해." }
    ];

    // 100세트(200문장) 생성 로직
    const finalDialogues = [];
    for(let i=0; i<100; i++) {
        const base = dialogueSource[i % dialogueSource.length];
        finalDialogues.push({ who: "WOMAN", ko: base.woman, de: "Die Perfektion ist eine Illusion.", en: "Perfection is a tuned illusion.", ja: "完璧は調律された幻想だ。" });
        finalDialogues.push({ who: "GIRL", ko: base.girl, de: "Ich berühre die wahre Erde.", en: "I touch the true texture of earth.", ja: "私は本当の土に触れる。" });
    }

    const idolCanvas = document.getElementById('idolCanvas');
    const girlCanvas = document.getElementById('girlCanvas');
    const crackCanvas = document.getElementById('crackCanvas');
    const ictx = idolCanvas.getContext('2d');
    const gctx = girlCanvas.getContext('2d');
    const cctx = crackCanvas.getContext('2d');
    const scroller = document.getElementById('credits-scroller');

    let width, height, dpr;
    let isDrawing = false;
    let lastX = 0, lastY = 0;
    let points = [];

    // --- Audio Engine: Warm Morse ---
    let audioCtx;
    function initAudio() { if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)(); }
    function playWarmMorse(duration = 0.1, freq = 440, volume = 0.1) {
        if (!audioCtx) return;
        const osc = audioCtx.createOscillator();
        const gain = audioCtx.createGain();
        const lowpass = audioCtx.createBiquadFilter();

        osc.type = 'triangle'; // 따뜻한 소리를 위해 triangle wave 사용
        osc.frequency.setValueAtTime(freq, audioCtx.currentTime);

        lowpass.type = 'lowpass';
        lowpass.frequency.setValueAtTime(800, audioCtx.currentTime);

        gain.gain.setValueAtTime(0, audioCtx.currentTime);
        gain.gain.linearRampToValueAtTime(volume, audioCtx.currentTime + 0.01);
        gain.gain.exponentialRampToValueAtTime(0.0001, audioCtx.currentTime + duration);

        osc.connect(lowpass);
        lowpass.connect(gain);
        gain.connect(audioCtx.destination);

        osc.start(); osc.stop(audioCtx.currentTime + duration);
    }

    // --- Morphing Logic ---
    let morphTime = 0;
    setInterval(() => {
        morphTime = 1 - morphTime;
        document.getElementById('img-woman').style.opacity = morphTime === 0 ? 1 : 0;
        document.getElementById('img-girl').style.opacity = morphTime === 1 ? 1 : 0;
    }, 9000);

    function resize() {
        dpr = window.devicePixelRatio || 1;
        width = window.innerWidth;
        height = window.innerHeight;
        idolCanvas.width = girlCanvas.width = crackCanvas.width = width * dpr;
        idolCanvas.height = girlCanvas.height = crackCanvas.height = height * dpr;
        ictx.scale(dpr, dpr); gctx.scale(dpr, dpr); cctx.scale(dpr, dpr);
        drawGrid();
    }

    function populateCredits() {
        finalDialogues.forEach(d => {
            const group = document.createElement('div');
            group.className = `dialogue-group group-${d.who.toLowerCase()}`;
            group.innerHTML = `
                <div class="persona-tag">${d.who === 'WOMAN' ? 'IDOL: MATURE_GOGO' : 'ARTIST: THE_GIRL'}</div>
                <div class="line-box">
                    <div class="lang-ko">${d.ko}</div>
                    <div class="lang-sub">${d.de} | ${d.en} | ${d.ja}</div>
                </div>
            `;
            scroller.appendChild(group);
        });
    }

    function drawGrid() {
        ictx.clearRect(0, 0, width, height);
        ictx.strokeStyle = 'rgba(0, 255, 255, 0.12)';
        ictx.lineWidth = 0.5;
        for(let x=0; x<width; x+=120) { ictx.beginPath(); ictx.moveTo(x,0); ictx.lineTo(x,height); ictx.stroke(); }
        for(let y=0; y<height; y+=120) { ictx.beginPath(); ictx.moveTo(0,y); ictx.lineTo(width,y); ictx.stroke(); }
    }

    function drawCrack(x, y) {
        cctx.strokeStyle = 'rgba(255, 255, 255, 0.4)';
        cctx.lineWidth = 1.5;
        const segments = 12 + Math.random() * 8;
        for(let i=0; i<segments; i++) {
            const angle = Math.random() * Math.PI * 2;
            const length = 50 + Math.random() * 150;
            cctx.beginPath();
            cctx.moveTo(x, y);
            cctx.lineTo(x + Math.cos(angle)*length, y + Math.sin(angle)*length);
            cctx.stroke();
        }
    }

    function drawLipKiss(x, y) {
        ictx.save();
        ictx.translate(x, y);
        ictx.rotate((Math.random() - 0.5) * 0.4);
        ictx.fillStyle = 'rgba(233, 30, 99, 0.7)';
        ictx.beginPath(); ictx.ellipse(-18, -6, 28, 14, -0.2, 0, Math.PI * 2); ictx.ellipse(18, -6, 28, 14, 0.2, 0, Math.PI * 2); ictx.fill();
        ictx.beginPath(); ictx.ellipse(0, 18, 45, 20, 0, 0, Math.PI * 2); ictx.fill();
        ictx.restore();
        playWarmMorse(0.35, 120, 0.2); // 깊은 비프
        drawCrack(x, y);
    }

    function drawRokkakuEnergy(x, y) {
        const dx = x - lastX;
        const dy = y - lastY;
        const speed = Math.sqrt(dx * dx + dy * dy);
        points.push({x, y, size: Math.max(18, speed * 1.3)});
        if(points.length > 18) points.shift();
        
        if (points.length > 3) {
            gctx.globalAlpha = 0.8;
            const colors = ['#ff007f', '#ffeb3b', '#00bcd4', '#ffffff', '#8bc34a'];
            gctx.strokeStyle = colors[Math.floor(Math.random() * colors.length)];
            gctx.lineCap = 'round'; gctx.lineJoin = 'round';
            gctx.beginPath();
            gctx.moveTo(points[0].x, points[0].y);
            for(let i=1; i<points.length-2; i++) {
                const xc = (points[i].x + points[i+1].x) / 2;
                const yc = (points[i].y + points[i+1].y) / 2;
                gctx.lineWidth = points[i].size;
                gctx.quadraticCurveTo(points[i].x, points[i].y, xc, yc);
            }
            gctx.stroke();
        }
        if (Math.random() > 0.8) playWarmMorse(0.08, 550 + speed, 0.1); // 빠른 도(Dot)
    }

    // --- Interaction ---
    const start = (x, y) => { initAudio(); isDrawing = true; [lastX, lastY] = [x, y]; points = []; drawLipKiss(x, y); };
    const move = (x, y) => { if(!isDrawing) return; drawRokkakuEnergy(x, y); [lastX, lastY] = [x, y]; };
    
    window.addEventListener('mousedown', e => start(e.clientX, e.clientY));
    window.addEventListener('mousemove', e => move(e.clientX, e.clientY));
    window.addEventListener('mouseup', () => isDrawing = false);
    window.addEventListener('touchstart', e => { const t = e.touches[0]; start(t.clientX, t.clientY); e.preventDefault(); }, {passive: false});
    window.addEventListener('touchmove', e => { const t = e.touches[0]; move(t.clientX, t.clientY); e.preventDefault(); }, {passive: false});
    window.addEventListener('touchend', () => isDrawing = false);
    window.addEventListener('resize', resize);

    function loop() {
        cctx.fillStyle = 'rgba(0, 0, 0, 0.04)';
        cctx.fillRect(0,0,width,height);
        ictx.fillStyle = 'rgba(0, 0, 0, 0.008)';
        ictx.fillRect(0, 0, width, height);
        requestAnimationFrame(loop);
    }

    window.onload = () => { resize(); populateCredits(); loop(); };
</script>
</body>
</html>
