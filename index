<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Glass Kiss: Pastel Cloud Homage</title>
    <style>
        :root {
            --bg-cardboard: #e5d1b8;
            --pastel-neon: #bc13fe;
            --rokkaku-pink: #ff007f;
            --rokkaku-yellow: #ffeb3b;
            --rokkaku-cyan: #00e5ff;
            --cloud-white: rgba(255, 255, 255, 0.95);
            --cloud-pink: rgba(255, 209, 220, 0.95);
            --cloud-blue: rgba(209, 240, 255, 0.95);
        }

        body, html {
            margin: 0; padding: 0;
            width: 100%; height: 100%;
            overflow: hidden;
            background-color: var(--bg-cardboard);
            font-family: 'Pretendard', -apple-system, sans-serif;
            color: #222;
        }

        #exhibition-stage {
            position: relative;
            width: 100%; height: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            background: var(--bg-cardboard);
        }

        #background-canvas {
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 100%;
            z-index: 0;
        }

        #subject-container {
            position: absolute;
            width: 75vh; height: 75vh;
            z-index: 5;
            pointer-events: none;
        }

        .subject-image {
            position: absolute;
            width: 100%; height: 100%;
            object-fit: cover;
            border-radius: 50%;
            filter: contrast(110%) saturate(1.2);
            transition: opacity 5s ease-in-out;
            mask-image: radial-gradient(circle, black 40%, transparent 90%);
            -webkit-mask-image: radial-gradient(circle, black 40%, transparent 90%);
        }

        #img-woman { opacity: 1; }
        #img-girl { opacity: 0; filter: contrast(130%) brightness(1.1); }

        /* 유리 장막 및 질감 */
        #glass-layer {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            pointer-events: none;
            z-index: 15;
            background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, transparent 40%, rgba(255,255,255,0.05) 100%);
            backdrop-filter: blur(1px);
        }

        #texture-overlay {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            pointer-events: none;
            z-index: 17;
            opacity: 0.35;
            background-image: url('https://www.transparenttextures.com/patterns/cardboard.png');
        }

        /* 대화 크레딧 레이어 */
        #credits-container {
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 100%;
            overflow: hidden;
            pointer-events: none;
            z-index: 25;
            mask-image: linear-gradient(to bottom, transparent 0%, black 10%, black 90%, transparent 100%);
            -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 10%, black 90%, transparent 100%);
        }

        #credits-scroller {
            position: absolute;
            top: 100%;
            width: 100%;
            display: flex;
            flex-direction: column;
            gap: 180px;
            animation: scroll-slow 200s linear infinite; 
        }

        .dialogue-group {
            display: flex;
            flex-direction: column;
            width: 100%;
            box-sizing: border-box;
            padding: 0 4%;
        }

        /* WOMAN (Mature): 완전 우측 정렬 */
        .group-woman { align-items: flex-end; }
        .group-woman .persona-tag { 
            color: var(--pastel-neon); 
            font-size: 11px; 
            letter-spacing: 5px; 
            font-weight: 800; 
            margin-bottom: 5px;
            margin-right: 20px;
        }

        /* 뭉게뭉게 구름 말풍선 (WOMAN) */
        .group-woman .line-box { 
            background: var(--cloud-blue);
            backdrop-filter: blur(8px);
            text-align: right; 
            padding: 25px 40px;
            max-width: 480px; /* 크기 축소 */
            border-radius: 50px 50px 5px 50px;
            box-shadow: 
                0 10px 30px rgba(0,0,0,0.05),
                15px -15px 0 -5px var(--cloud-blue),
                -15px -10px 0 -8px var(--cloud-blue);
            position: relative;
        }

        /* GIRL (Rokkaku): 완전 좌측 정렬 */
        .group-girl { align-items: flex-start; }
        .group-girl .persona-tag { 
            color: var(--rokkaku-pink); 
            font-size: 11px; 
            letter-spacing: 5px; 
            font-weight: 800; 
            margin-bottom: 5px;
            margin-left: 20px;
        }

        /* 뭉게뭉게 구름 말풍선 (GIRL) */
        .group-girl .line-box { 
            background: var(--cloud-pink);
            backdrop-filter: blur(8px);
            text-align: left; 
            padding: 25px 40px;
            max-width: 480px; /* 크기 축소 */
            border-radius: 50px 50px 50px 5px;
            box-shadow: 
                0 10px 30px rgba(0,0,0,0.05),
                -15px -15px 0 -5px var(--cloud-pink),
                15px -10px 0 -8px var(--cloud-pink);
            position: relative;
        }

        .lang-parallel { display: flex; flex-direction: column; gap: 6px; }
        .lang-ko { font-size: 24px; font-weight: 900; color: #333; line-height: 1.1; }
        .lang-en { font-size: 13px; color: #555; font-weight: 600; }
        .lang-de { font-size: 12px; color: #777; font-style: italic; }
        .lang-ja { font-size: 13px; color: #666; font-family: 'Noto Sans JP', sans-serif; }

        @keyframes scroll-slow {
            0% { transform: translateY(0); }
            100% { transform: translateY(-70000px); } 
        }

        #ui-panel {
            position: absolute;
            bottom: 30px; left: 30px;
            z-index: 40;
            padding: 20px;
            background: rgba(229, 209, 184, 0.7);
            font-family: monospace;
            color: #444;
            font-size: 12px;
            pointer-events: none;
            line-height: 1.6;
            border-radius: 8px;
            border: 1px solid rgba(0,0,0,0.1);
        }

        #ui-panel span { color: var(--rokkaku-pink); font-weight: bold; }
    </style>
</head>
<body>

<div id="exhibition-stage">
    <canvas id="background-canvas"></canvas>

    <div id="subject-container">
        <img id="img-woman" class="subject-image" src="https://images.unsplash.com/photo-1531746020798-e6953c6e8e04?q=80&w=1200&auto=format&fit=crop" alt="WOMAN Persona">
        <img id="img-girl" class="subject-image" src="https://images.unsplash.com/photo-1508186225823-0963cf9ab0de?q=80&w=1200&auto=format&fit=crop" alt="Rokkaku Style Girl">
    </div>

    <div id="glass-layer"></div>
    <div id="texture-overlay"></div>
    
    <div id="credits-container">
        <div id="credits-scroller"></div>
    </div>

    <div id="ui-panel">
        [STATION: ROKKAKU_PASTEL_CLOUDS]<br>
        [INTERACTION: STATIC_OBSERVATION]<br>
        [AESTHETIC: <span>PASTEL</span>_PUFFY_BUBBLES]
    </div>
</div>

<script>
const dialogueSource = [
  {
    woman: {
      ko: "완벽한 군무는 상징계적 법의 완성이다.",
      en: "Perfect choreography is the completion of the symbolic law.",
      de: "Perfekte Choreografie ist die Vollendung des symbolischen Gesetzes.",
      ja: "完璧な群舞は象徴界的な法の完成だ。"
    },
    girl: {
      ko: "그 법은 감옥일 뿐, 나의 붓질은 탈주선이다.",
      en: "That law is just a prison; my brushstroke is a line of flight.",
      de: "Dieses Gesetz ist nur ein Gefängnis; mein Pinselstrich ist eine Fluchtlinie.",
      ja: "その法は監獄に過ぎず、私の筆致は脱走線だ。"
    }
  },
  {
    woman: {
      ko: "유리창 너머의 입맞춤은 조율된 환상이야.",
      en: "A kiss through the glass is a tuned illusion.",
      de: "Ein Kuss durch das Glas ist eine abgestimmte Illusion.",
      ja: "ガラス越しの口づけは調律された幻想だ。"
    },
    girl: {
      ko: "나는 유리를 깨고 진짜 흙의 차가움을 만질 거야.",
      en: "I will break the glass and feel the cold earth.",
      de: "Ich werde das Glas brechen und die kalte Erde fühlen.",
      ja: "私はガラスを割って本物の土の冷たさに触れる。"
    }
  },
  {
    woman: {
      ko: "나의 성숙함은 대타자의 법이 만든 조각품이지.",
      en: "My maturity is a sculpture made by the law of the Big Other.",
      de: "Meine Reife ist eine Skulptur, geschaffen durch das Gesetz des Großen Anderen.",
      ja: "私の成熟は大他者の法が作った彫刻品だ。"
    },
    girl: {
      ko: "나의 미성숙은 누구도 셈하지 못한 사건의 폭발이야.",
      en: "My immaturity is an explosion of an uncounted event.",
      de: "Meine Unreife ist die Explosion eines ungezählten Ereignisses.",
      ja: "私の未成熟は、誰も数えることができなかった事件の爆発だ。"
    }
  },
  {
    woman: {
      ko: "질서 안에서만 진정한 아름다움이 빛나.",
      en: "True beauty shines only within order.",
      de: "Wahre Schönheit strahlt nur innerhalb der Ordnung.",
      ja: "秩序の中でこそ本当の美しさが輝く。"
    },
    girl: {
      ko: "혼돈의 호흡이 멈추는 곳에 예술은 없어.",
      en: "There is no art where the breath of chaos stops.",
      de: "Wo der Atem des Chaos stoppt, gibt es keine Kunst.",
      ja: "混沌の呼吸が止まる場所に芸術はない。"
    }
  },
  {
    woman: {
      ko: "연습된 눈빛은 수만 명의 욕망을 투영해.",
      en: "A practiced gaze projects the desires of tens of thousands.",
      de: "Ein geübter Blick projiziert die Wünsche von Zehntausenden.",
      ja: "訓練された眼差しは数万人の欲望を投影する。"
    },
    girl: {
      ko: "우연히 튄 물감 자국 속에 진짜 내 얼굴이 있어.",
      en: "My real face is within the accidental paint splatters.",
      de: "Mein wahres Gesicht liegt in den zufälligen Farbspritzern.",
      ja: "偶然跳ねた絵の具の跡の中に本当の私の顔がある。"
    }
  },
  {
    woman: {
      ko: "시스템은 우리를 영원하게 박제해 줄 거야.",
      en: "The system will preserve us eternally like taxidermy.",
      de: "Das System wird uns ewig konservieren wie eine Taxidermie.",
      ja: "システムは私たちを永遠に剥製にしてくれるだろう。"
    },
    girl: {
      ko: "사라지는 순간의 강렬함이 박제된 영원보다 위대해.",
      en: "The intensity of a fleeting moment is greater than preserved eternity.",
      de: "Die Intensität eines flüchtigen Augenblicks ist größer als die bewahrte Ewigkeit.",
      ja: "消えゆく瞬間の強烈さは剥製された永遠より偉大だ。"
    }
  },
  {
    woman: {
      ko: "거울 단계의 통일성이 주체의 자부심이다.",
      en: "The unity of the mirror stage is the subject's pride.",
      de: "Die Einheit des Spiegelstadiums ist der Stolz des Subjekts.",
      ja: "鏡像段階の統一性が主体の自負だ。"
    },
    girl: {
      ko: "조각난 파편들이 내뱉는 비명이 주체의 진실이다.",
      en: "The screams of fragmented shards are the subject's truth.",
      de: "Die Schreie der fragmentierten Scherben sind die Wahrheit des Subjekts.",
      ja: "断片化された破片が吐き出す悲鳴が主体の真実だ。"
    }
  },
  {
    woman: {
      ko: "두려워. 나라는 코드가 지워지는 순간이.",
      en: "I'm scared. The moment the code of 'me' is erased.",
      de: "Ich habe Angst. Der Moment, in dem der Code von 'mir' gelöscht wird.",
      ja: "怖い。私というコードが消される瞬間が。"
    },
    girl: {
      ko: "지워지는 게 아니라, 나의 색채 속에 녹아들어 영원한 호흡이 되는 거야.",
      en: "Not erased, but melting into my colors to become an eternal breath.",
      de: "Nicht gelöscht, sondern in meine Farben verschmolzen, um ein ewiger Atem zu werden.",
      ja: "消されるのではなく、私の色彩の中に溶け込んで永遠の呼吸になるのだ。"
    }
  },
  {
    woman: {
      ko: "마지막 노래가 끝나가...",
      en: "The last song is coming to an end...",
      de: "Das letzte Lied geht zu Ende...",
      ja: "最後の歌が終わっていく…"
    },
    girl: {
      ko: "부서진 틈 사이로 진짜 흙의 냄새가 나지 않니?",
      en: "Can't you smell the true earth through the broken gaps?",
      de: "Riechst du nicht die wahre Erde durch die zerbrochenen Lücken?",
      ja: "壊れた隙間から本当の土の匂いがしない？"
    }
  }
];


    const finalDialogues = [];
    for(let i=0; i<100; i++) {
        const base = dialogueSource[i % dialogueSource.length];
        finalDialogues.push({ who: "WOMAN", data: base.woman });
        finalDialogues.push({ who: "GIRL", data: base.girl });
    }

    const bgCanvas = document.getElementById('background-canvas');
    const bgctx = bgCanvas.getContext('2d');
    const scroller = document.getElementById('credits-scroller');

    let width, height, dpr;

    function resize() {
        dpr = window.devicePixelRatio || 1;
        width = window.innerWidth;
        height = window.innerHeight;
        bgCanvas.width = width * dpr;
        bgCanvas.height = height * dpr;
        bgctx.setTransform(1, 0, 0, 1, 0, 0);
        bgctx.scale(dpr, dpr);
        drawRokkakuBG();
    }

    // 아야코 록카쿠 스타일의 배경 생성기 (파스텔 강화)
    function drawRokkakuBG() {
        bgctx.fillStyle = '#e5d1b8'; 
        bgctx.fillRect(0, 0, width, height);
        
        const colors = ['#ff85b3', '#fff4a3', '#a3f0ff', '#c2ff85', '#ffffff', '#ffab85'];
        
        // 거친 파스텔 구름
        for(let i=0; i<50; i++) {
            const x = Math.random() * width;
            const y = Math.random() * height;
            const radius = 50 + Math.random() * 200;
            const color = colors[Math.floor(Math.random() * colors.length)];
            bgctx.save();
            bgctx.globalAlpha = 0.15;
            bgctx.fillStyle = color;
            bgctx.beginPath();
            for(let j=0; j<8; j++) {
                bgctx.arc(x + (Math.random()-0.5)*130, y + (Math.random()-0.5)*130, radius * (0.3+Math.random()), 0, Math.PI*2);
            }
            bgctx.fill();
            bgctx.restore();
        }

        // 튀긴 물감 효과
        for(let m=0; m<300; m++) {
            bgctx.globalAlpha = 0.3;
            bgctx.fillStyle = colors[Math.floor(Math.random() * colors.length)];
            bgctx.beginPath();
            bgctx.arc(Math.random() * width, Math.random() * height, Math.random() * 4, 0, Math.PI * 2);
            bgctx.fill();
        }
    }

    function drawRokkakuEye(ctx, x, y, size) {
        ctx.save();
        ctx.translate(x, y);
        ctx.rotate((Math.random() - 0.5) * 0.4);
        ctx.globalAlpha = 0.2;
        ctx.fillStyle = '#fff';
        ctx.beginPath(); ctx.ellipse(0, 0, size, size * 0.5, 0, 0, Math.PI * 2); ctx.fill();
        ctx.lineWidth = 1.5; ctx.strokeStyle = '#333'; ctx.stroke();
        ctx.fillStyle = '#222';
        ctx.beginPath(); ctx.arc(size * 0.2, -size * 0.1, size * 0.35, 0, Math.PI * 2); ctx.fill();
        ctx.restore();
    }

    function populateCredits() {
        finalDialogues.forEach(d => {
            const group = document.createElement('div');
            group.className = `dialogue-group group-${d.who.toLowerCase() === 'woman' ? 'woman' : 'girl'}`;
            group.innerHTML = `
                <div class="persona-tag">${d.who === 'WOMAN' ? 'SYSTEM : WOMAN' : 'INSTINCT : GIRL'}</div>
                <div class="line-box">
                    <div class="lang-parallel">
                        <div class="lang-ko">${d.data.ko}</div>
                        <div class="lang-en">${d.data.en}</div>
                        <div class="lang-de">${d.data.de}</div>
                        <div class="lang-ja">${d.data.ja}</div>
                    </div>
                </div>
            `;
            scroller.appendChild(group);
        });
    }

    window.addEventListener('resize', resize);

    // 모핑 사이클
    setInterval(() => {
        const womanImg = document.getElementById('img-woman');
        const girlImg = document.getElementById('img-girl');
        const currentWomanOp = parseFloat(getComputedStyle(womanImg).opacity);
        womanImg.style.opacity = currentWomanOp === 1 ? 0 : 1;
        girlImg.style.opacity = currentWomanOp === 1 ? 1 : 0;
    }, 12000);

    function loop() {
        // 배경의 미세한 맥동 효과 (재그리기 방지 및 최적화)
        if(Math.random() > 0.998) drawRokkakuBG();
        requestAnimationFrame(loop);
    }

    window.onload = () => { resize(); populateCredits(); loop(); };
</script>
</body>
</html>
