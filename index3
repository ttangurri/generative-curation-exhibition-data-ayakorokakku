<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Glass Kiss: The Boundary of Desire</title>
    <style>
        :root {
            --bg-cardboard: #d8c4a9;
            --idol-neon: #bc13fe;
            --idol-cyan: #0ff;
            --rokkaku-pink: #ff007f;
            --rokkaku-yellow: #ffeb3b;
            --oriental-gold: #d4af37;
            --lip-red: #e91e63;
        }

        body, html {
            margin: 0; padding: 0;
            width: 100%; height: 100%;
            overflow: hidden;
            background-color: #050505;
            font-family: 'Pretendard', -apple-system, sans-serif;
            color: #fff;
            cursor: crosshair;
        }

        #exhibition-stage {
            position: relative;
            width: 100%; height: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            background: #000;
        }

        /* 탈 구름, 눈, 색채의 소용돌이 */
        #background-canvas {
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 100%;
            z-index: 0;
            opacity: 0.6;
            filter: contrast(110%);
        }

        /* 인물 전시 레이어 */
        #subject-container {
            position: absolute;
            width: 80vh; height: 80vh;
            z-index: 5;
            pointer-events: none;
        }

        .subject-image {
            position: absolute;
            width: 100%; height: 100%;
            object-fit: cover;
            border-radius: 50%;
            filter: contrast(120%) brightness(0.8);
            transition: opacity 6s ease-in-out;
            mask-image: radial-gradient(circle, black 30%, transparent 85%);
            -webkit-mask-image: radial-gradient(circle, black 30%, transparent 85%);
        }

        #img-woman { opacity: 1; }
        #img-girl { opacity: 0; }

        /* 유리 장막 레이어 */
        #glass-layer {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            pointer-events: none;
            z-index: 15;
            background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, transparent 50%, rgba(255,255,255,0.05) 100%);
            backdrop-filter: blur(2px);
        }

        #texture-overlay {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            pointer-events: none;
            z-index: 17;
            opacity: 0.2;
            background-image: url('https://www.transparenttextures.com/patterns/cardboard.png');
        }

        canvas.interactive-canvas {
            position: absolute;
            top: 0; left: 0;
            display: block;
        }

        /* 대화 크레딧 레이어 */
        #credits-container {
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 100%;
            overflow: hidden;
            pointer-events: none;
            z-index: 25;
            mask-image: linear-gradient(to bottom, transparent 0%, black 20%, black 80%, transparent 100%);
            -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 20%, black 80%, transparent 100%);
        }

        #credits-scroller {
            position: absolute;
            top: 100%;
            width: 100%;
            display: flex;
            flex-direction: column;
            gap: 150px;
            animation: scroll-slow 120s linear infinite; 
        }

        .dialogue-group {
            display: flex;
            flex-direction: column;
            width: 100%;
            box-sizing: border-box;
            padding: 0 10%;
        }

        /* IDOL 상단 표시 */
        .group-woman { align-items: flex-end; }
        .group-woman .persona-tag { color: var(--idol-neon); font-size: 13px; letter-spacing: 6px; font-weight: 900; margin-bottom: 12px; text-shadow: 0 0 10px var(--idol-neon); }
        .group-woman .line-box { 
            border-right: 10px solid var(--idol-neon); 
            background: rgba(15, 5, 20, 0.9);
            backdrop-filter: blur(20px);
            text-align: right; 
            padding: 30px 45px;
            max-width: 650px;
            box-shadow: 20px 20px 0px rgba(188, 19, 254, 0.1);
        }

        /* GIRL 상단 표시 */
        .group-girl { align-items: flex-start; }
        .group-girl .persona-tag { color: var(--rokkaku-pink); font-size: 13px; letter-spacing: 6px; font-weight: 900; margin-bottom: 12px; }
        .group-girl .line-box { 
            border: 8px solid var(--rokkaku-pink);
            background: rgba(40, 10, 20, 0.9);
            backdrop-filter: blur(20px);
            text-align: left; 
            padding: 30px 45px;
            max-width: 650px;
            border-radius: 100px 30px 120px 15px;
            box-shadow: -20px 20px 0px rgba(255, 0, 127, 0.1);
        }

        .lang-parallel { display: flex; flex-direction: column; gap: 10px; }
        .lang-ko { font-size: 30px; font-weight: 800; color: #fff; line-height: 1.1; }
        .lang-en { font-size: 16px; color: #aaa; }
        .lang-de { font-size: 14px; color: #888; font-style: italic; }
        .lang-ja { font-size: 16px; color: #777; font-family: 'Noto Sans JP', sans-serif; }

        @keyframes scroll-slow {
            0% { transform: translateY(0); }
            100% { transform: translateY(-45000px); } 
        }

        #ui-panel {
            position: absolute;
            bottom: 50px; left: 50px;
            z-index: 40;
            padding: 30px;
            border: 3px solid var(--oriental-gold);
            background: rgba(0,0,0,0.7);
            font-family: monospace;
            color: var(--oriental-gold);
            font-size: 14px;
            pointer-events: none;
            line-height: 2;
            border-radius: 15px 50px 10px 40px;
        }

        #ui-panel span { color: var(--rokkaku-pink); font-weight: bold; }
    </style>
</head>
<body>

<div id="exhibition-stage">
    <!-- 배경 -->
    <canvas id="background-canvas"></canvas>

    <div id="subject-container">
        <img id="img-woman" class="subject-image" src="https://images.unsplash.com/photo-1516726817505-f5ed825624d8?q=80&w=1200&auto=format&fit=crop" alt="Mature Idol Persona">
        <img id="img-girl" class="subject-image" src="https://images.unsplash.com/photo-1621252179027-94459d278660?q=80&w=1200&auto=format&fit=crop" alt="Pigtail Girl Persona">
    </div>

    <div id="glass-layer"></div>
    <div id="texture-overlay"></div>
    
    <canvas id="idolCanvas" class="interactive-canvas"></canvas>
    <canvas id="girlCanvas" class="interactive-canvas"></canvas>
    <canvas id="crackCanvas" class="interactive-canvas"></canvas>
    
    <div id="credits-container">
        <div id="credits-scroller"></div>
    </div>

    <div id="ui-panel">
        [OBJECT: ORIENTAL_MYSTERY_STATION]<br>
        [AESTHETIC: <span>AYAKO_ROKKAKU</span>_GIRL_HOMAGE]<br>
        [SIGNAL: BREATHING_WITH_THE_CHAOS]
    </div>
</div>

<script>
    /**
     * Dialogue Data (100 Sets)
     */
    const dialogueSource = [
        {
            woman: { ko: "완벽함은 연습과 시스템에서 태어나.", en: "Perfection is born from practice and systems.", de: "Perfektion wird durch Übung und System geboren.", ja: "完璧は練習とシステムから生まれる。" },
            girl: { ko: "자유는 내 손끝의 본능에서 흘러나와.", en: "Freedom flows from the instinct of my fingertips.", de: "Freiheit fließt aus dem Instinkt meiner Fingerspitzen.", ja: "自由は私の指先の本能から流れ出す。" }
        },
        {
            woman: { ko: "유리창 너머의 입맞춤은 조율된 환상이야.", en: "A kiss through the glass is a tuned illusion.", de: "Ein Kuss durch das Glas ist eine abgestimmte Illusion.", ja: "ガラス越しの口づけは調律された幻想だ。" },
            girl: { ko: "나는 유리를 깨고 진짜 흙의 차가움을 만질 거야.", en: "I will break the glass and feel the cold earth.", de: "Ich werde das Glas brechen und die kalte Erde fühlen.", ja: "私はガラスを割って本物の土の冷たさに触れる。" }
        },
        {
            woman: { ko: "나의 성숙함은 법이 만든 조각품이지.", en: "My maturity is a sculpture made by the law.", de: "Meine Reife ist eine vom Gesetz geschaffene Skulptur.", ja: "私の成熟は法が作った彫刻品だ。" },
            girl: { ko: "나의 미성숙은 사건의 폭발이야.", en: "My immaturity is an explosion of an event.", de: "Meine Unreife ist eine Explosion eines Ereignisses.", ja: "私の未成熟は事件の폭발だ。" }
        }
    ];

    const finalDialogues = [];
    for(let i=0; i<100; i++) {
        const base = dialogueSource[i % dialogueSource.length];
        finalDialogues.push({ who: "IDOL", data: base.woman }); // WOMAN 대신 IDOL 유지
        finalDialogues.push({ who: "GIRL", data: base.girl });
    }

    const bgCanvas = document.getElementById('background-canvas');
    const idolCanvas = document.getElementById('idolCanvas');
    const girlCanvas = document.getElementById('girlCanvas');
    const crackCanvas = document.getElementById('crackCanvas');
    const bgctx = bgCanvas.getContext('2d');
    const ictx = idolCanvas.getContext('2d');
    const gctx = girlCanvas.getContext('2d');
    const cctx = crackCanvas.getContext('2d');
    const scroller = document.getElementById('credits-scroller');

    let width, height, dpr;
    let isDrawing = false;
    let lastX = 0, lastY = 0;
    let points = [];

    // --- Audio Engine ---
    let audioCtx;
    function initAudio() { if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)(); }
    function playWarmMorse(duration = 0.1, freq = 440, volume = 0.15) {
        if (!audioCtx) return;
        const osc = audioCtx.createOscillator();
        const gain = audioCtx.createGain();
        osc.type = 'triangle';
        osc.frequency.setValueAtTime(freq, audioCtx.currentTime);
        gain.gain.setValueAtTime(0, audioCtx.currentTime);
        gain.gain.linearRampToValueAtTime(volume, audioCtx.currentTime + 0.01);
        gain.gain.exponentialRampToValueAtTime(0.0001, audioCtx.currentTime + duration);
        osc.connect(gain); gain.connect(audioCtx.destination);
        osc.start(); osc.stop(audioCtx.currentTime + duration);
    }

    function resize() {
        dpr = window.devicePixelRatio || 1;
        width = window.innerWidth;
        height = window.innerHeight;
        bgCanvas.width = idolCanvas.width = girlCanvas.width = crackCanvas.width = width * dpr;
        bgCanvas.height = idolCanvas.height = girlCanvas.height = crackCanvas.height = height * dpr;
        bgctx.scale(dpr, dpr); ictx.scale(dpr, dpr); gctx.scale(dpr, dpr); cctx.scale(dpr, dpr);
        drawGrid();
        drawRokkakuBG();
    }

    //  배경 그리기
    function drawRokkakuBG() {
        bgctx.clearRect(0,0,width,height);
        
        // 1. 색채의 소용돌이 구름 (우키요에 스타일)
        const cloudColors = ['#ff007f', '#ffeb3b', '#00bcd4', '#d4af37', '#ffffff'];
        for(let i=0; i<25; i++) {
            const x = Math.random() * width;
            const y = Math.random() * height;
            const size = 100 + Math.random() * 400;
            bgctx.beginPath();
            bgctx.globalAlpha = 0.1;
            bgctx.fillStyle = cloudColors[i % cloudColors.length];
            
            // 유기적인 구름 형태
            bgctx.arc(x, y, size/2, 0, Math.PI * 2);
            bgctx.arc(x + size/4, y + size/6, size/3, 0, Math.PI * 2);
            bgctx.fill();
        }

        // 2. 록카쿠의 상징: 큰 눈(Large Eyes)
        for(let j=0; j<8; j++) {
            const ex = Math.random() * width;
            const ey = Math.random() * height;
            drawStaringEye(ex, ey, 50 + Math.random() * 50);
        }

        // 3. 아야코 록카쿠의 물감 점(Dots) - 무수히 많은 색채
        for(let k=0; k<150; k++) {
            bgctx.globalAlpha = 0.2;
            bgctx.fillStyle = cloudColors[Math.floor(Math.random() * cloudColors.length)];
            bgctx.beginPath();
            bgctx.arc(Math.random() * width, Math.random() * height, Math.random() * 8, 0, Math.PI * 2);
            bgctx.fill();
        }
    }

    function drawStaringEye(x, y, size) {
        bgctx.save();
        bgctx.translate(x, y);
        bgctx.rotate((Math.random() - 0.5) * 0.2);
        bgctx.globalAlpha = 0.15;
        
        // 눈 흰자
        bgctx.fillStyle = '#fff';
        bgctx.beginPath();
        bgctx.ellipse(0, 0, size, size * 0.6, 0, 0, Math.PI * 2);
        bgctx.fill();
        
        // 눈동자
        bgctx.fillStyle = '#000';
        bgctx.beginPath();
        bgctx.arc(0, 0, size * 0.3, 0, Math.PI * 2);
        bgctx.fill();
        
        bgctx.restore();
    }

    function populateCredits() {
        finalDialogues.forEach(d => {
            const group = document.createElement('div');
            group.className = `dialogue-group group-${d.who.toLowerCase() === 'idol' ? 'woman' : 'girl'}`;
            group.innerHTML = `
                <div class="persona-tag">${d.who}</div>
                <div class="line-box">
                    <div class="lang-parallel">
                        <div class="lang-ko">${d.data.ko}</div>
                        <div class="lang-en">${d.data.en}</div>
                        <div class="lang-de">${d.data.de}</div>
                        <div class="lang-ja">${d.data.ja}</div>
                    </div>
                </div>
            `;
            scroller.appendChild(group);
        });
    }

    function drawGrid() {
        ictx.clearRect(0, 0, width, height);
        ictx.strokeStyle = 'rgba(0, 255, 255, 0.05)';
        ictx.lineWidth = 1;
        for(let x=0; x<width; x+=160) { ictx.beginPath(); ictx.moveTo(x,0); ictx.lineTo(x,height); ictx.stroke(); }
        for(let y=0; y<height; y+=160) { ictx.beginPath(); ictx.moveTo(0,y); ictx.lineTo(width,y); ictx.stroke(); }
    }

    function drawCrack(x, y) {
        cctx.strokeStyle = 'rgba(255, 255, 255, 0.4)';
        cctx.lineWidth = 1.5;
        for(let i=0; i<15; i++) {
            const angle = Math.random() * Math.PI * 2;
            const length = 50 + Math.random() * 200;
            cctx.beginPath();
            cctx.moveTo(x, y);
            cctx.lineTo(x + Math.cos(angle)*length, y + Math.sin(angle)*length);
            cctx.stroke();
        }
    }

    function drawLipKiss(x, y) {
        ictx.save();
        ictx.translate(x, y);
        ictx.rotate((Math.random() - 0.5) * 0.4);
        ictx.fillStyle = 'rgba(233, 30, 99, 0.7)';
        ictx.beginPath(); ictx.ellipse(-24, -10, 35, 18, -0.2, 0, Math.PI * 2); ictx.ellipse(24, -10, 35, 18, 0.2, 0, Math.PI * 2); ictx.fill();
        ictx.beginPath(); ictx.ellipse(0, 25, 55, 28, 0, 0, Math.PI * 2); ictx.fill();
        ictx.restore();
        playWarmMorse(0.4, 120, 0.2);
        drawCrack(x, y);
    }

    function drawRokkakuEnergy(x, y) {
        const dx = x - lastX;
        const dy = y - lastY;
        const speed = Math.sqrt(dx * dx + dy * dy);
        points.push({x, y, size: Math.max(25, speed * 2)});
        if(points.length > 30) points.shift();
        
        if (points.length > 3) {
            gctx.globalAlpha = 0.9;
            const colors = ['#ff007f', '#ffeb3b', '#00bcd4', '#ffffff', '#d4af37'];
            gctx.strokeStyle = colors[Math.floor(Math.random() * colors.length)];
            gctx.lineCap = 'round'; gctx.lineJoin = 'round';
            gctx.beginPath();
            gctx.moveTo(points[0].x, points[0].y);
            for(let i=1; i<points.length-2; i++) {
                const xc = (points[i].x + points[i+1].x) / 2;
                const yc = (points[i].y + points[i+1].y) / 2;
                gctx.lineWidth = points[i].size;
                gctx.quadraticCurveTo(points[i].x, points[i].y, xc, yc);
            }
            gctx.stroke();
            
            if (speed > 60 && Math.random() > 0.4) {
                gctx.fillStyle = gctx.strokeStyle;
                gctx.beginPath();
                gctx.arc(x + (Math.random()-0.5)*150, y + (Math.random()-0.5)*150, Math.random()*15, 0, Math.PI*2);
                gctx.fill();
            }
        }
        if (Math.random() > 0.88) playWarmMorse(0.1, 550 + speed, 0.12);
    }

    const start = (x, y) => { initAudio(); isDrawing = true; [lastX, lastY] = [x, y]; points = []; drawLipKiss(x, y); };
    const move = (x, y) => { if(!isDrawing) return; drawRokkakuEnergy(x, y); [lastX, lastY] = [x, y]; };
    
    window.addEventListener('mousedown', e => start(e.clientX, e.clientY));
    window.addEventListener('mousemove', e => move(e.clientX, e.clientY));
    window.addEventListener('mouseup', () => isDrawing = false);
    window.addEventListener('touchstart', e => { const t = e.touches[0]; start(t.clientX, t.clientY); e.preventDefault(); }, {passive: false});
    window.addEventListener('touchmove', e => { const t = e.touches[0]; move(t.clientX, t.clientY); e.preventDefault(); }, {passive: false});
    window.addEventListener('touchend', () => isDrawing = false);
    window.addEventListener('resize', resize);

    // Morphing: 15초 주기
    let mPhase = 0;
    setInterval(() => {
        mPhase = 1 - mPhase;
        document.getElementById('img-woman').style.opacity = mPhase === 0 ? 1 : 0;
        document.getElementById('img-girl').style.opacity = mPhase === 1 ? 1 : 0;
    }, 15000);

    function loop() {
        cctx.fillStyle = 'rgba(0, 0, 0, 0.02)';
        cctx.fillRect(0,0,width,height);
        ictx.fillStyle = 'rgba(0, 0, 0, 0.003)';
        ictx.fillRect(0, 0, width, height);
        
        // 배경의 미세한 맥동 (신비로운 효과)
        bgctx.globalAlpha = 0.005;
        bgctx.fillStyle = '#000';
        bgctx.fillRect(0,0,width,height);
        if(Math.random() > 0.99) drawRokkakuBG();

        requestAnimationFrame(loop);
    }

    window.onload = () => { resize(); populateCredits(); loop(); };
</script>
</body>
</html>
