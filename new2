<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Circular Arena - Interactive Art</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            margin: 0;
            overflow: hidden;
            /* 배경을 부드러운 파스텔 톤으로 변경 */
            background-color: #f7f3f9; 
            color: #333;
            font-family: 'Pretendard', sans-serif;
        }
        canvas {
            display: block;
            touch-action: none;
        }
        #ui-overlay {
            position: absolute;
            top: 20px;
            left: 20px;
            pointer-events: none;
            opacity: 0.8;
            transition: opacity 0.3s;
        }
        #ui-overlay:hover { opacity: 1; }
        .instructions {
            font-size: 0.8rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }
    </style>
</head>
<body>

    <div id="ui-overlay">
        <h1 class="text-2xl font-bold mb-1 text-pink-600">CIRCULAR ARENA</h1>
        <p class="instructions text-gray-500">Move to swirl • Click to burst</p>
    </div>

    <canvas id="artCanvas"></canvas>

    <script>
        /**
         * Circular Arena - Interactive Art
         * 원본 이미지의 색상과 형태를 기반으로 한 입자 시뮬레이션
         */

        const canvas = document.getElementById('artCanvas');
        const ctx = canvas.getContext('2d');

        let width, height;
        let particles = [];
        let ripples = [];
        let mouse = { x: -1000, y: -1000, active: false };
        
        // 원본 이미지에서 추출한 핵심 팔레트
        const palette = [
            '#4CAF50', // Vibrant Green
            '#E91E63', // Pink
            '#FFC107', // Gold/Yellow
            '#03A9F4', // Sky Blue
            '#FF5722', // Orange/Red
            '#F8BBD0', // Soft Pink
            '#C8E6C9'  // Soft Green
        ];

        // 이미지 객체 생성
        const mainImage = new Image();
        mainImage.src = 'image_f5fb34.jpg'; 

        function init() {
            resize();
            createParticles();
            animate();
        }

        function resize() {
            width = window.innerWidth;
            height = window.innerHeight;
            canvas.width = width;
            canvas.height = height;
        }

        window.addEventListener('resize', resize);

        class Particle {
            constructor() {
                this.reset();
            }

            reset() {
                this.x = Math.random() * width;
                this.y = Math.random() * height;
                this.baseX = this.x;
                this.baseY = this.y;
                // 1. 입자 크기를 더 크게 조정 (기존 1~4 -> 4~12)
                this.size = Math.random() * 8 + 4;
                this.color = palette[Math.floor(Math.random() * palette.length)];
                this.vx = (Math.random() - 0.5) * 1.5;
                this.vy = (Math.random() - 0.5) * 1.5;
                this.life = Math.random();
                this.angle = Math.random() * Math.PI * 2;
                this.distanceFromCenter = Math.sqrt(Math.pow(this.x - width/2, 2) + Math.pow(this.y - height/2, 2));
            }

            update() {
                const dx = width / 2 - this.x;
                const dy = height / 2 - this.y;
                const dist = Math.sqrt(dx * dx + dy * dy);

                const mdx = mouse.x - this.x;
                const mdy = mouse.y - this.y;
                const mdist = Math.sqrt(mdx * mdx + mdy * mdy);
                
                if (mdist < 150) {
                    const angle = Math.atan2(mdy, mdx);
                    this.vx -= Math.cos(angle) * 0.2;
                    this.vy -= Math.sin(angle) * 0.2;
                }

                const rotateAngle = Math.atan2(dy, dx) + 0.01;
                const targetX = width / 2 + Math.cos(rotateAngle) * dist;
                const targetY = height / 2 + Math.sin(rotateAngle) * dist;

                this.vx += (targetX - this.x) * 0.001;
                this.vy += (targetY - this.y) * 0.001;

                this.x += this.vx;
                this.y += this.vy;
                this.vx *= 0.98;
                this.vy *= 0.98;

                ripples.forEach(r => {
                    const rdx = r.x - this.x;
                    const rdy = r.y - this.y;
                    const rdist = Math.sqrt(rdx * rdx + rdy * rdy);
                    if (Math.abs(rdist - r.radius) < 15) {
                        const angle = Math.atan2(rdy, rdx);
                        this.vx -= Math.cos(angle) * r.power;
                        this.vy -= Math.sin(angle) * r.power;
                    }
                });
            }

            draw() {
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                ctx.fillStyle = this.color;
                // 입자가 겹칠 때 색이 부드럽게 섞이도록 투명도 조절
                ctx.globalAlpha = 0.7;
                ctx.fill();
                ctx.globalAlpha = 1.0;
            }
        }

        function createParticles() {
            particles = [];
            const count = (width * height) / 4000; // 입자 크기가 커졌으므로 밀도를 약간 조정
            for (let i = 0; i < count; i++) {
                particles.push(new Particle());
            }
        }

        function drawMainCircle() {
            const centerX = width / 2;
            const centerY = height / 2;
            const radius = Math.min(width, height) * 0.35;

            const grad = ctx.createRadialGradient(centerX, centerY, 0, centerX, centerY, radius * 1.5);
            grad.addColorStop(0, 'rgba(233, 30, 99, 0.05)');
            grad.addColorStop(1, 'transparent');
            ctx.fillStyle = grad;
            ctx.fillRect(0, 0, width, height);

            ctx.save();
            ctx.beginPath();
            ctx.arc(centerX, centerY, radius, 0, Math.PI * 2);
            ctx.clip();
            
            try {
                if (mainImage.complete && mainImage.naturalHeight !== 0) {
                    ctx.drawImage(mainImage, centerX - radius, centerY - radius, radius * 2, radius * 2);
                } else {
                    ctx.strokeStyle = 'rgba(0,0,0,0.1)';
                    ctx.lineWidth = 2;
                    ctx.stroke();
                }
            } catch(e) {}
            
            ctx.restore();
            
            ctx.beginPath();
            ctx.arc(centerX, centerY, radius + 2, 0, Math.PI * 2);
            ctx.strokeStyle = 'rgba(0,0,0,0.05)';
            ctx.stroke();
        }

        function animate() {
            // 2. 배경 톤에 맞춘 잔상 효과 (어두운 색 -> 밝은 색)
            ctx.fillStyle = 'rgba(247, 243, 249, 0.2)'; 
            ctx.fillRect(0, 0, width, height);

            drawMainCircle();

            particles.forEach(p => {
                p.update();
                p.draw();
            });

            for (let i = ripples.length - 1; i >= 0; i--) {
                ripples[i].radius += 10;
                ripples[i].life -= 0.02;
                if (ripples[i].life <= 0) ripples.splice(i, 1);
                else {
                    ctx.beginPath();
                    ctx.arc(ripples[i].x, ripples[i].y, ripples[i].radius, 0, Math.PI * 2);
                    // 리플 색상을 어두운 톤으로 변경하여 밝은 배경에서 잘 보이게 함
                    ctx.strokeStyle = `rgba(233, 30, 99, ${ripples[i].life * 0.4})`;
                    ctx.stroke();
                }
            }

            requestAnimationFrame(animate);
        }

        const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        function playNote(freq, type = 'sine', decay = 1) {
            const osc = audioCtx.createOscillator();
            const gain = audioCtx.createGain();
            osc.type = type;
            osc.frequency.setValueAtTime(freq, audioCtx.currentTime);
            gain.gain.setValueAtTime(0.05, audioCtx.currentTime);
            gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + decay);
            osc.connect(gain);
            gain.connect(audioCtx.destination);
            osc.start();
            osc.stop(audioCtx.currentTime + decay);
        }

        function handleInteraction(e) {
            const x = e.clientX || (e.touches && e.touches[0].clientX);
            const y = e.clientY || (e.touches && e.touches[0].clientY);
            mouse.x = x;
            mouse.y = y;
        }

        window.addEventListener('mousemove', handleInteraction);
        window.addEventListener('touchstart', (e) => {
            if (audioCtx.state === 'suspended') audioCtx.resume();
            handleInteraction(e);
            triggerRipple(mouse.x, mouse.y);
        });

        window.addEventListener('mousedown', () => {
            if (audioCtx.state === 'suspended') audioCtx.resume();
            triggerRipple(mouse.x, mouse.y);
        });

        function triggerRipple(x, y) {
            ripples.push({ x, y, radius: 0, life: 1, power: 7 });
            const notes = [329.63, 392.00, 440.00, 523.25, 587.33];
            playNote(notes[Math.floor(Math.random() * notes.length)], 'sine', 1.5);
            
            for(let i=0; i<15; i++) {
                const p = new Particle();
                p.x = x; p.y = y;
                p.size = Math.random() * 10 + 5;
                p.vx = (Math.random()-0.5) * 12;
                p.vy = (Math.random()-0.5) * 12;
                particles.push(p);
                if (particles.length > 800) particles.shift();
            }
        }

        init();
    </script>
</body>
</html>
